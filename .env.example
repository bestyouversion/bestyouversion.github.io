# ===========================================
# SUPABASE
# ===========================================
# Get these from: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ===========================================
# PAYMONGO
# ===========================================
# Get these from: https://dashboard.paymongo.com → Developers → API Keys
VITE_PAYMONGO_PUBLIC_KEY=pk_test_xxxxxxxxxxxx

# The secret key is ONLY used in Supabase Edge Functions, never in frontend
# PAYMONGO_SECRET_KEY=sk_test_xxxxxxxxxxxx

# ===========================================
# GOOGLE CALENDAR (used in Supabase Edge Functions only)
# ===========================================
# GOOGLE_CALENDAR_ID=your-calendar-id@gmail.com
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ===========================================
# CONTACT FORM (Web3Forms — free, no backend)
# ===========================================
# 1. Go to https://web3forms.com
# 2. Enter ade@bestyouversion.com → click "Create Access Key"
# 3. Confirm via email link Web3Forms sends to ade@bestyouversion.com
# 4. Paste the access key below
VITE_WEB3FORMS_ACCESS_KEY=your-web3forms-access-key-here
